# ============================================
# EnvSetup.dev — Environment Variables
# Copy this file to .env.local and fill values
# ============================================

# --- Database (Neon DB — free tier) ---
# Get from: https://neon.tech → New Project → Connection string
DATABASE_URL=postgresql://<user>:<password>@<host>/<dbname>?sslmode=require

# --- AI (choose one) ---
# Option 1: Groq (FREE) → https://console.groq.com
GROQ_API_KEY=gsk_...

# Option 2: OpenAI (paid) → https://platform.openai.com
# OPENAI_API_KEY=sk-...

# --- Email / Newsletter (Brevo — free 300/day) ---
# Get from: https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-...

# --- Admin Dashboard ---
# Set a strong password — never commit real values!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password

# --- Vercel Cron Security ---
# Random secret to protect /api/cron endpoints
CRON_SECRET=random_secret_here
